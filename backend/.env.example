# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/trrip

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Access token TTL (short-lived — default 15m)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token TTL is hardcoded to 7 days and stored in an httpOnly cookie

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=trrip-documents

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Global: 100 req / 15 min (per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Auth: 10 failed attempts / 15 min (hardcoded)
# Upload: 20 uploads / 10 min (hardcoded)
# AI Gen: 15 itineraries / hour (hardcoded)

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=debug
